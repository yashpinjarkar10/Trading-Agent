# Trading Agent Environment Variables
# Copy this file to .env and fill in your API keys

# Required: Google Gemini API key for AI chat functionality
# Get your key from: https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: News API key for enhanced news analysis
# Get your key from: https://newsapi.org/
NEWS_API_KEY=your_news_api_key_here

# Optional: LangSmith API key for debugging and monitoring
# Get your key from: https://smith.langchain.com/
LANGSMITH_API_KEY=your_langsmith_api_key_here

# Optional: Enable LangSmith tracing (true/false)
LANGSMITH_TRACING=false

# Optional: Port configuration (defaults to 7860 for Hugging Face Spaces)
PORT=7860
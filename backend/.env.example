# Trading Agent Backend Environment Variables
# Copy this file to .env and fill in your API keys

# Required: Google Gemini API key for AI chat functionality
# Get your key from: https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: News API key for enhanced news analysis
# Get your key from: https://newsapi.org/
NEWS_API_KEY=your_news_api_key_here

# Optional: LangSmith API key for debugging and monitoring
# Get your key from: https://smith.langchain.com/
LANGSMITH_API_KEY=your_langsmith_api_key_here

# Optional: Enable LangSmith tracing (true/false)
LANGSMITH_TRACING=false

# Backend Configuration
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional: Debug mode
DEBUG=false
LOG_LEVEL=info

# Redis cache (optional — app falls back to in-process cache if unreachable)
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=true

# Cache TTLs in seconds (defaults shown)
CACHE_TTL_OHLCV=900
CACHE_TTL_FUNDAMENTALS=3600
CACHE_TTL_NEWS=300
CACHE_TTL_TICKER_VALIDATION=604800

# LangGraph chat memory (SQLite, persistent across restarts)
LANGGRAPH_DB_PATH=data/langgraph_checkpoints.sqlite

# ─────────────────────────────────────────────────────────────────────────────
# Event Map — Supabase client (read-only from the backend)
# Writes (scrapers, LLM enrichment, retention) happen via /scrapers on
# GitHub Actions. Those have their own .env with the same SUPABASE_* keys
# plus extra source-specific keys (NASA_FIRMS_API_KEY, etc).
# See SUPABASE_SETUP.md for project setup.
# ─────────────────────────────────────────────────────────────────────────────
EVENTS_ENABLED=false

SUPABASE_URL=https://[project].supabase.co
SUPABASE_SERVICE_ROLE_KEY=    # used by backend for reads — bypasses RLS, keep secret
SUPABASE_ANON_KEY=            # frontend uses this for Realtime subscriptions (sb_publishable_...)

# ── Source-specific keys (only needed when running the corresponding scraper) ──
# NASA FIRMS (wildfires). Free signup, ~60 seconds:
#   https://firms.modaps.eosdis.nasa.gov/api/area/
# Used by `python -m scraper.scripts.run_firms`.
NASA_FIRMS_API_KEY=
